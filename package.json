{
  "name": "black-souls-mcp",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "description": "Local stdio MCP bridge for BLACK SOULS and RPG Maker VX Ace / RGSS3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yk4464/black-souls-mcp.git"
  },
  "homepage": "https://github.com/yk4464/black-souls-mcp#readme",
  "bugs": {
    "url": "https://github.com/yk4464/black-souls-mcp/issues"
  },
  "license": "MIT",
  "author": "yk4464",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rpg-maker-vx-ace",
    "rgss3",
    "black-souls"
  ],
  "bin": {
    "black-souls-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "rgss/*.rb",
    "scripts/*.mjs",
    "scripts/*.py",
    "*.ps1",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "README.en.md",
    "requirements-tools.txt"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "node scripts/smoke.mjs && node scripts/unit.mjs",
    "test:integration": "node scripts/integration.mjs",
    "test:live": "node scripts/live_e2e.mjs",
    "check": "npm run build && npm run test",
    "live:e2e": "npm run test:live",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
